# GitHub Personal Access Token (with repo & admin:org scopes)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Organisation GitHub
ORG_NAME=Kazo-ca

# Préfixe pour les noms de runners
RUNNER_PREFIX=worker-shadow

# Labels des runners (utilisé par l'autoscaler pour filtrer)
RUNNER_LABELS=tower,linux

# ── Autoscaling ──
# Nombre minimum de runners (jamais en dessous)
MIN_RUNNERS=2
# Nombre maximum de runners (jamais au dessus)
MAX_RUNNERS=10
# Nombre minimum de runners idle à garder libre
MIN_IDLE=1
# Intervalle de vérification en secondes
CHECK_INTERVAL=30
